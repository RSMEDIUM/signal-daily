# OPTIONAL Environment Variables
# The application works perfectly WITHOUT this file (uses SQLite + console email)
# Only create a .env file if you need custom database or production settings

# Database Configuration (OPTIONAL - defaults to SQLite)
# Uncomment and configure only if using MySQL/MariaDB
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=signaldaily_db
# DB_USER=signaldaily_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=3306

# Email Configuration (OPTIONAL - defaults to console output)
# Uncomment only if you want real email sending
# DEFAULT_FROM_EMAIL=noreply@signaldaily.com
# SITE_URL=http://localhost:8000
