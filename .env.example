# Database Configuration
# Use 'django.db.backends.sqlite3' for SQLite (default)
# Use 'django.db.backends.mysql' for MariaDB/MySQL
DB_ENGINE=django.db.backends.mysql

# MariaDB/MySQL Connection Details
DB_NAME=signaldaily_db
DB_USER=signaldaily_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=3306

